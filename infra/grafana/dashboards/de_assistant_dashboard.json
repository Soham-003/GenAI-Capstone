{
  "id": null,
  "title": "DE Assistant Health",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "assistant_requests_total", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Quality Checks Triggered",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "assistant_quality_checks_total", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Latency p95",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(assistant_request_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" }
}
